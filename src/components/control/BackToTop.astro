---
import { Icon } from "astro-icon/components";
---

<div style="position: fixed; right: 0; top: 0; width: 80px; height: 300px; pointer-events: none; z-index: 49;">
    <div id="go-to-comments-btn" class="btn-float" style="position: fixed; bottom: 170px; right: 16px; width: 60px; height: 60px; background: var(--card-bg); color: var(--primary); border: 2px solid var(--primary); border-radius: 16px; display: none; align-items: center; justify-content: center; cursor: pointer; pointer-events: auto;" onclick="goToComments()">
        <Icon name="material-symbols:chat-rounded" style="font-size: 28px;"></Icon>
    </div>
    <div id="back-to-top-btn" class="btn-float" style="position: fixed; bottom: 100px; right: 16px; width: 60px; height: 60px; background: var(--card-bg); color: var(--primary); border: 2px solid var(--primary); border-radius: 16px; display: none; align-items: center; justify-content: center; cursor: pointer; pointer-events: auto;" onclick="backToTop()">
        <Icon name="material-symbols:keyboard-arrow-up-rounded" style="font-size: 28px;"></Icon>
    </div>
</div>

<style is:global>
@media (max-width: 640px) {
    .btn-float {
        width: 48px !important;
        height: 48px !important;
    }
    .btn-float svg {
        font-size: 24px !important;
    }
}
</style>

<script is:raw is:inline>
function backToTop() {
    window.scroll({ top: 0, behavior: 'smooth' });
}

function goToComments() {
    const comments = document.getElementById('giscus-container');
    if (comments) {
        comments.scrollIntoView({ behavior: 'smooth' });
    }
}

function updateButtons() {
    const isArticlePage = window.location.pathname.startsWith('/posts/');
    const goToCommentsBtn = document.getElementById('go-to-comments-btn');
    const backToTopBtn = document.getElementById('back-to-top-btn');
    const scrollY = window.scrollY || window.pageYOffset;
    
    if (goToCommentsBtn && backToTopBtn) {
        if (isArticlePage) {
            goToCommentsBtn.style.display = 'flex';
            backToTopBtn.style.display = 'flex';
        } else {
            goToCommentsBtn.style.display = 'none';
            if (scrollY > 300) {
                backToTopBtn.style.display = 'flex';
            } else {
                backToTopBtn.style.display = 'none';
            }
        }
    }
}

function init() {
    updateButtons();
    window.addEventListener('scroll', updateButtons, { passive: true });
    window.addEventListener('resize', updateButtons);
    
    if (typeof Swup !== 'undefined') {
        document.addEventListener('swup:navigate', updateButtons);
    } else {
        window.addEventListener('popstate', updateButtons);
    }
}

if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', init);
} else {
    init();
}
</script>
